{
  "name": "fantasy-football",
  "version": "1.0.0",
  "description": "Fantasy NFL Draft Assistant & Season Manager",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "session-file-store": "^1.5.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
