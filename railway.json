{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm install --prefix client && npm run build"
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node server/index.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
